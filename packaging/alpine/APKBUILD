# Maintainer: Warren MacEvoy <wmacevoy@gmail.com>
pkgname=libutf8
pkgver=1.0.0
pkgrel=0
pkgdesc="Small permissive UTF-8 encode/decode library"
url="https://github.com/wmacevoy/utf8"
arch="all"
license="Unlicense"
makedepends="cmake"
subpackages="$pkgname-dev $pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/wmacevoy/utf8/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/utf8-$pkgver"

build() {
	cmake -B build \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

check() {
	cd build
	ctest --output-on-failure
}

package() {
	cmake --install build --prefix "$pkgdir/usr"
}

# Update after creating release tarball:
#   sha512sum v1.0.0.tar.gz
sha512sums="PLACEHOLDER"
